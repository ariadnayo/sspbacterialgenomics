#k-mer
from collections import Counter
import numpy as np

def kmer_profile(seqs, k=6):
    kmers = Counter()
    for seq in seqs:
        for i in range(len(seq) - k + 1):
            kmer = seq[i:i+k]
            kmers[kmer] += 1
    return kmers

def normalize_counter(counter, all_keys):
    return np.array([counter.get(k, 0) for k in all_keys])

