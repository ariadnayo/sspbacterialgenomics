def extract_reads(file, max_reads=1000, format="fasta-pearson"):  #используем fasta-pearson
    reads = []
    for i, record in enumerate(SeqIO.parse(file, format)):
        reads.append(str(record.seq))
        if i == max_reads:
            break
    return reads
