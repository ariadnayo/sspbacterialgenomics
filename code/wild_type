def break_long_seq_into_reads(file, read_length=150, max_reads=1000):
    reads = []
    for record in SeqIO.parse(file, "fasta"):
        seq = str(record.seq)
        for i in range(0, len(seq) - read_length + 1, read_length):
            reads.append(seq[i:i+read_length])
            if len(reads) >= max_reads:
                return reads
    return reads

